<Window x:Class="PhoneCamUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PhoneCam" Height="760" Width="560"
        MinHeight="720" MinWidth="520"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA" Foreground="#152033"
        ResizeMode="CanResize">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#0F172A" Padding="24,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="PhoneCam" FontSize="28" FontWeight="SemiBold" Foreground="White"/>
                    <TextBlock Text="Android camera to Zoom" FontSize="13" Foreground="#CBD5E1" Margin="0,4,0,0"/>
                </StackPanel>

                <Border Grid.Column="1" Background="#18243A" CornerRadius="8" Padding="12,8"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="statusDot" Width="10" Height="10" Fill="#EF4444"
                                 Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="txtStatus" Text="Disconnected" FontSize="13"
                                   Foreground="#E2E8F0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24">
                <Border Background="White" CornerRadius="8" Padding="18" BorderBrush="#E2E8F0" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Connect" FontSize="18" FontWeight="SemiBold" Foreground="#0F172A"/>
                        <TextBlock x:Name="txtDeviceStatus" Text="USB is recommended for Zoom quality."
                                   FontSize="12" Foreground="#64748B" Margin="0,4,0,14"/>

                        <UniformGrid Columns="3" Margin="0,0,0,14">
                            <RadioButton x:Name="rbUsb" Content="USB" IsChecked="True"
                                         Style="{StaticResource SegmentRadioButton}"
                                         Checked="OnConnectionModeChanged"/>
                            <RadioButton x:Name="rbWifi" Content="WiFi"
                                         Style="{StaticResource SegmentRadioButton}"
                                         Checked="OnConnectionModeChanged"/>
                            <RadioButton x:Name="rbBluetooth" Content="Bluetooth"
                                         Style="{StaticResource SegmentRadioButton}"
                                         Checked="OnConnectionModeChanged"/>
                        </UniformGrid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="96"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock x:Name="txtAddressLabel" Text="Address" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="txtAddress" Text="127.0.0.1" Style="{StaticResource TextInput}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Port" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="txtPort" Text="4747" Style="{StaticResource TextInput}"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Text="Start resolution" Style="{StaticResource FieldLabel}"/>
                                <ComboBox x:Name="cboResolution" SelectedIndex="0" Style="{StaticResource SelectInput}">
                                    <ComboBoxItem Content="640 x 480"/>
                                    <ComboBoxItem Content="1280 x 720"/>
                                    <ComboBoxItem Content="1920 x 1080"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Zoom" Style="{StaticResource FieldLabel}"/>
                                <Button Content="Open Zoom" Style="{StaticResource SecondaryButton}"
                                        Click="OnOpenZoomClick"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Margin="0,14,0,0">
                            <TextBlock Text="Phone mic output for Zoom mic bridge" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="txtMicOutput" Text=""
                                     Style="{StaticResource TextInput}"
                                     ToolTip="Optional. Use a virtual cable playback device name such as CABLE Input. Leave empty for default speaker."/>
                        </StackPanel>

                        <Button x:Name="btnConnect" Content="Connect Phone" Height="48"
                                Margin="0,18,0,0" FontSize="15"
                                Style="{StaticResource PrimaryButton}"
                                Click="OnConnectClick"/>

                        <ProgressBar x:Name="progressConnect" Height="4" Margin="0,12,0,0"
                                     IsIndeterminate="True" Visibility="Collapsed"
                                     Foreground="#2563EB" Background="#DBEAFE"/>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="8" Padding="18" BorderBrush="#E2E8F0"
                        BorderThickness="1" Margin="0,16,0,0" x:Name="grpControls" IsEnabled="False">
                    <StackPanel>
                        <TextBlock Text="Camera Controls" FontSize="18" FontWeight="SemiBold" Foreground="#0F172A"/>

                        <UniformGrid Columns="4" Margin="0,14,0,0">
                            <Button Content="Flip" Style="{StaticResource ToolButton}" Click="OnFlipCamera"/>
                            <Button Content="Rotate" Style="{StaticResource ToolButton}" Click="OnRotateCamera"/>
                            <Button Content="Flash" Style="{StaticResource ToolButton}" Click="OnToggleFlash"/>
                            <Button Content="Focus" Style="{StaticResource ToolButton}" Click="OnAutoFocus"/>
                        </UniformGrid>

                        <UniformGrid Columns="3" Margin="0,10,0,0">
                            <Button x:Name="btnAudioToggle" Content="Mute Audio"
                                    Style="{StaticResource ToolButton}" Click="OnToggleAudio"/>
                            <Button x:Name="btnPhoneSpeaker" Content="Phone Speaker"
                                    Style="{StaticResource ToolButton}" Click="OnTogglePhoneSpeaker"/>
                            <Button Content="Keyframe" Style="{StaticResource ToolButton}" Click="OnRequestKeyframe"/>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="8" Padding="18" BorderBrush="#E2E8F0"
                        BorderThickness="1" Margin="0,16,0,0" x:Name="grpRemote" IsEnabled="False">
                    <StackPanel>
                        <TextBlock Text="Stream Tuning" FontSize="18" FontWeight="SemiBold" Foreground="#0F172A"/>

                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="72"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="56"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Zoom" Grid.Column="0" VerticalAlignment="Center" Foreground="#475569"/>
                            <Slider x:Name="sldZoom" Grid.Column="1" Minimum="100" Maximum="800"
                                    Value="100" TickFrequency="50" ValueChanged="OnZoomChanged"/>
                            <TextBlock x:Name="txtZoom" Grid.Column="2" Text="1.0x"
                                       VerticalAlignment="Center" TextAlignment="Right" Foreground="#475569"/>
                        </Grid>

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="72"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="88"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Bitrate" Grid.Column="0" VerticalAlignment="Center" Foreground="#475569"/>
                            <Slider x:Name="sldBitrate" Grid.Column="1" Minimum="500" Maximum="20000"
                                    Value="5000" TickFrequency="500" ValueChanged="OnBitrateChanged"/>
                            <TextBlock x:Name="txtBitrate" Grid.Column="2" Text="5000 kbps"
                                       VerticalAlignment="Center" TextAlignment="Right" Foreground="#475569"/>
                        </Grid>

                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="96"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="cboLiveResolution" SelectedIndex="0"
                                      Style="{StaticResource SelectInput}">
                                <ComboBoxItem Content="640 x 480"/>
                                <ComboBoxItem Content="1280 x 720"/>
                                <ComboBoxItem Content="1920 x 1080"/>
                            </ComboBox>
                            <Button Grid.Column="1" Content="Apply" Margin="12,0,0,0"
                                    Style="{StaticResource SecondaryButton}" Click="OnApplyResolution"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Background="White" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0"
                Padding="24,12">
            <TextBlock x:Name="txtStats" Text="Ready" FontSize="12" Foreground="#64748B"/>
        </Border>
    </Grid>
</Window>
